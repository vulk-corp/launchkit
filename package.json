{
  "name": "@bworlds/launchkit",
  "version": "1.5.0",
  "description": "Monitoring, error capture, and access gating SDK for AI-built apps",
  "type": "module",
  "main": "./dist/launchkit.js",
  "module": "./dist/launchkit.js",
  "browser": "./dist/launchkit.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/launchkit.js",
      "import": "./dist/launchkit.js",
      "require": "./dist/launchkit.cjs",
      "default": "./dist/launchkit.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "rrweb": "2.0.0-alpha.18"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "jsdom": "^29.0.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "launchkit",
    "monitoring",
    "error-tracking",
    "heartbeat",
    "bworlds",
    "lovable",
    "bolt",
    "ai-builder"
  ],
  "author": "BWorlds",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://www.npmjs.com/package/@bworlds/launchkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/vulk-corp/launchkit.git"
  }
}
